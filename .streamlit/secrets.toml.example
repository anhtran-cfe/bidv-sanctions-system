# ---------------------------------------------------------------------------
# Streamlit secrets TEMPLATE for the BIDV Sanctions System
#
# This .example file is committed to the PUBLIC repo, so it contains
# PLACEHOLDERS ONLY. Never put real API keys here.
#
# Where real keys go:
#   - Streamlit Cloud (the deployed app):
#       App page -> Manage app -> Settings -> Secrets
#       Paste the GEMINI_API_KEYS block below with your real key values.
#   - Local testing on your machine:
#       Copy this file to  .streamlit/secrets.toml  (that filename is
#       gitignored) and fill in real values.
#
# How the app uses these keys:
#   All keys are pooled. Each request is load-balanced round-robin across the
#   keys, and automatically fails over to the next key when one hits its
#   rate limit / quota. More keys = higher combined throughput.
# ---------------------------------------------------------------------------

# RECOMMENDED — a list of all your Gemini API keys:
GEMINI_API_KEYS = [
    "YOUR_GEMINI_API_KEY_1",
    "YOUR_GEMINI_API_KEY_2",
    "YOUR_GEMINI_API_KEY_3",
    "YOUR_GEMINI_API_KEY_4",
    "YOUR_GEMINI_API_KEY_5",
    "YOUR_GEMINI_API_KEY_6",
    "YOUR_GEMINI_API_KEY_7",
    "YOUR_GEMINI_API_KEY_8",
    "YOUR_GEMINI_API_KEY_9",
    "YOUR_GEMINI_API_KEY_10",
]

# ----------------------------------------------------------------------------
# Alternative formats the app also accepts (use ONE style; the list above is
# easiest). Uncomment if you prefer them.
#
# Numbered keys:
# GEMINI_API_KEY_1 = "YOUR_GEMINI_API_KEY_1"
# GEMINI_API_KEY_2 = "YOUR_GEMINI_API_KEY_2"
# ... up to GEMINI_API_KEY_50
#
# Single key (backward compatible with the old setup):
# GEMINI_API_KEY = "YOUR_SINGLE_GEMINI_API_KEY"
# ----------------------------------------------------------------------------
